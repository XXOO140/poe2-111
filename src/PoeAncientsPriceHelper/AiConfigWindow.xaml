<Window x:Class="PoeAncientsPriceHelper.AiConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 识别配置" Height="350" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E"
        Foreground="#E0E0E0"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- OCR 引擎选择 -->
        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="OCR 引擎:" Foreground="#4ecca3" FontSize="14" Margin="0,0,0,10"/>
        
        <RadioButton Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                     x:Name="TesseractRadio" Content="Tesseract (内置，支持中文简繁+英文)"
                     Foreground="#E0E0E0" FontSize="12" Margin="20,0,0,10"
                     GroupName="OcrEngine" IsChecked="True"/>
        
        <RadioButton Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                     x:Name="AiRadio" Content="AI 识别 (使用 AI API 识别，需配置 API)"
                     Foreground="#AA66FF" FontSize="12" Margin="20,0,0,15"
                     GroupName="OcrEngine"/>

        <!-- API 配置 -->
        <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="AI API 配置 (仅 AI 识别模式需要):"
                   Foreground="#4ecca3" FontSize="12" Margin="0,0,0,10"/>

        <!-- API 端点 -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="API 端点:"
                   Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
        <TextBox Grid.Row="5" Grid.Column="1" x:Name="ApiEndpointTextBox"
                 Text="https://api.openai.com/v1/chat/completions"
                 Background="#0F3460" Foreground="#E0E0E0" BorderBrush="#2A4A6C"
                 Padding="5" Margin="0,4"/>

        <!-- API 密钥 -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="API 密钥:"
                   Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
        <PasswordBox Grid.Row="6" Grid.Column="1" x:Name="ApiKeyPasswordBox"
                     Background="#0F3460" Foreground="#E0E0E0" BorderBrush="#2A4A6C"
                     Padding="5" Margin="0,4"/>

        <!-- 模型 -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="模型:"
                   Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
        <TextBox Grid.Row="7" Grid.Column="1" x:Name="ModelTextBox"
                 Text="gpt-4o-mini"
                 Background="#0F3460" Foreground="#E0E0E0" BorderBrush="#2A4A6C"
                 Padding="5" Margin="0,4"/>

        <!-- 测试区域 -->
        <Border Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#0F3460" BorderBrush="#2A4A6C" BorderThickness="1"
                CornerRadius="4" Padding="10" Margin="0,15,0,0">
            <StackPanel>
                <TextBlock Text="AI 测试" Foreground="#4ecca3" FontSize="12" Margin="0,0,0,10"/>
                <Button x:Name="TestAiButton" Content="测试 AI 识别"
                        Background="#2A1A3A" Foreground="#AA66FF" BorderBrush="#553377"
                        Padding="15,8" HorizontalAlignment="Left"
                        Click="TestAiButton_Click"/>
                <TextBlock x:Name="TestResultText" Text=""
                           Foreground="#E0E0E0" FontSize="11" Margin="0,10,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- 按钮 -->
        <StackPanel Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
            <Button Content="保存" Padding="20,8" Margin="0,0,10,0"
                    Background="#1A3A1A" Foreground="#66FF66" BorderBrush="#337733"
                    Click="SaveButton_Click"/>
            <Button Content="取消" Padding="20,8"
                    Background="#3A1A1A" Foreground="#FF6666" BorderBrush="#773333"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
