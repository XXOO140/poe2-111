<mah:MetroWindow x:Class="PoeAncientsPriceHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="PoE2 物价助手" Height="450" Width="500"
        Icon="app.ico"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F0F"
        Foreground="#E0E0E0"
        BorderBrush="#2A2A2A"
        TitleCharacterCasing="Normal"
        Closing="Window_Closing">

    <mah:MetroWindow.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="联赛:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="LeagueBox" Margin="0,4" SelectionChanged="LeagueBox_SelectionChanged"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="区域:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RegionLabel" Text="未校准" Foreground="#666" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="校准键:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
            <TextBlock x:Name="CalibrateHotkeyLabel" Text="F4" VerticalAlignment="Center"
                       FontFamily="Consolas" FontSize="12" Foreground="#E0E0E0" MinWidth="46"/>
            <Button x:Name="RebindCalibrateButton" Content="重新绑定" Padding="10,2" FontSize="11"
                    Click="RebindCalibrateButton_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="启动/停止键:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
            <TextBlock x:Name="HotkeyLabel" Text="F5" VerticalAlignment="Center"
                       FontFamily="Consolas" FontSize="12" Foreground="#E0E0E0" MinWidth="46"/>
            <Button x:Name="RebindButton" Content="重新绑定" Padding="10,2" FontSize="11"
                    Click="RebindButton_Click"/>
        </StackPanel>

        <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                x:Name="CalibrateButton"
                Content="校准区域" Margin="0,10,0,0"
                Click="CalibrateButton_Click"/>

        <!-- 价格同步状态 -->
        <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" 
                Background="#1A1A2E" BorderBrush="#2A2A4E" BorderThickness="1" 
                CornerRadius="6" Margin="0,10,0,0" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Row="0" Grid.Column="0" Text="价格同步:" 
                           Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SyncStatusLabel" 
                           Text="等待同步..." Foreground="#4ecca3" FontSize="11" VerticalAlignment="Center"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="上次同步:" 
                           Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="LastSyncLabel" 
                           Text="-" Foreground="#E0E0E0" FontSize="11" VerticalAlignment="Center"/>
                
                <TextBlock Grid.Row="2" Grid.Column="0" Text="同步次数:" 
                           Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="SyncCountLabel" 
                           Text="0" Foreground="#E0E0E0" FontSize="11" VerticalAlignment="Center"/>
                
                <TextBlock Grid.Row="3" Grid.Column="0" Text="物品数量:" 
                           Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ItemCountLabel" 
                           Text="0" Foreground="#E0E0E0" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                   x:Name="StatusLabel"
                   Text="空闲 — 价格未加载"
                   Foreground="#666" FontSize="11" Margin="0,10,0,0"/>

        <Button Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                x:Name="StartStopButton"
                Content="启动" IsEnabled="False"
                Margin="0,10,0,0"
                Background="#1A3A1A" Foreground="#66FF66" BorderBrush="#337733"
                Click="StartStopButton_Click"/>
                
        <Button Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                x:Name="SyncButton"
                Content="手动同步价格" Margin="0,6,0,0"
                Background="#1A2A3A" Foreground="#66AAFF" BorderBrush="#335577"
                Click="SyncButton_Click"/>

        <TextBlock Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                   x:Name="VersionLabel"
                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                   Foreground="#666" FontSize="11"/>

        <Button Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                x:Name="DonateButton"
                Content="☕ 请我喝咖啡"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Padding="10,4" FontSize="11" Cursor="Hand"
                Background="#3A2A12" Foreground="#E0B060" BorderBrush="#7A5A20"
                ToolTip="通过 PayPal 支持开发 — 谢谢！"
                Click="DonateButton_Click"/>
    </Grid>
</mah:MetroWindow>
